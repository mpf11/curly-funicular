<Window x:Class="WheelSwitcher.WheelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        WindowStartupLocation="Manual"
        Title="Wheel Switcher"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid x:Name="RootGrid" Opacity="0">
        <!-- Backdrop: a radial dim so content behind reads softer, but still visible -->
        <Rectangle x:Name="Backdrop" IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush x:Name="BackdropBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Offset="0.0" Color="#66000000"/>
                    <GradientStop Offset="0.6" Color="#44000000"/>
                    <GradientStop Offset="1.0" Color="#22000000"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Host canvas: thumbnails are hosted as HwndHost-like elements; we also draw
             the glass section overlay, dividers, icons, titles here. -->
        <Canvas x:Name="WheelCanvas" IsHitTestVisible="True" Background="Transparent">
            <Canvas.CacheMode>
                <BitmapCache />
            </Canvas.CacheMode>
        </Canvas>

        <!-- Hint text centered at the bottom -->
        <TextBlock x:Name="HintText"
                   Text="Move to select  ·  Click+drag to rearrange  ·  Release Alt to switch  ·  Esc to cancel"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,48"
                   Foreground="#BBFFFFFF"
                   FontSize="13"
                   FontFamily="Segoe UI Variable Display, Segoe UI"
                   IsHitTestVisible="False">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="Black" Opacity="0.6"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>
